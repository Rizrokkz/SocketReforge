items.Ingredient_Leather_Dark.name = Dunkles Leder

items.Ingredient_Leather_Heavy.name = Schweres Leder
items.Ingredient_Leather_Heavy.description = Aus den dicken Häuten von Spitzenprädatoren verarbeitet.\n\n<i>Jeder Jäger träumt davon, Kreaturen zu erlegen, von denen man nur in Legenden hört. Abgesehen von wenigen, die sich im Zeitalter der Helden zusammenschlossen, müssen sich die meisten stattdessen mit Bären, Wölfen und anderen Spitzenprädatoren zufriedengeben.</i>

items.Ingredient_Leather_Light.name = Leichtes Leder
items.Ingredient_Leather_Light.description = Aus den Häuten gewöhnlicher Beutetiere verarbeitet, die überall in der Wildnis zu finden sind.

items.Ingredient_Leather_Medium.name = Mittleres Leder
items.Ingredient_Leather_Medium.description = Aus den widerstandsfähigen Häuten mittelgroßer Gefahren und gepanzerter Bestien verarbeitet.

items.Ingredient_Leather_Prismic.name = Prismatisches Leder
items.Ingredient_Leather_Scaled.name = Schuppenleder
items.Ingredient_Leather_Soft.name = Weiches Leder
items.Ingredient_Leather_Storm.name = Sturmleder

