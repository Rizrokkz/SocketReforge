items.Ingredient_Poop.name = Kacke
items.Ingredient_Powder_Boom.name = Knallpulver

items.Ingredient_Fire_Essence.name = Essenz des Feuers
items.Ingredient_Fire_Essence.description = <i>Diese Energie gab einst den Träumen von Crucibles Kunsthandwerkern Gestalt. Heute verweilt sie nur noch in den Kreaturen, die in den verwüsteten Vulkanregionen leben.</i>

items.Ingredient_Ice_Essence.name = Essenz des Eises
items.Ingredient_Ice_Essence.description = <i>Als die Outlander die Flamme ablehnten und sich von ihren Brüdern trennten, wandten sie sich stattdessen den kälteren Regionen zu – und der zerbrechlichen Stärke, die in den vorrückenden Eisflächen liegt.</i>

items.Ingredient_Life_Essence.name = Essenz des Lebens
items.Ingredient_Life_Essence.description = <i>Eine Form überschäumender Lebensenergie, die auf Orbis in großer Menge rund um Pflanzen zu finden ist. In ausreichend hoher Konzentration könnte sie vielleicht sogar Bewusstsein hervorbringen, wo zuvor keines war.</i>

items.Ingredient_Life_Essence_Concentrated.name = Große Essenz des Lebens
items.Ingredient_Life_Essence_Concentrated.description = Eine Verschmelzung, die dem Gegenwert von <color is="#3e9049">100 Essenzen des Lebens</color> entspricht.

items.Ingredient_Lightning_Essence.name = Essenz des Blitzes
items.Ingredient_Lightning_Essence.description = <i>Tobende Stürme haben im Laufe der Jahrhunderte viele Kreaturen angezogen. Auch wenn die wahre Quelle solcher Magie nirgends zu finden ist, streifen die aus ihren verbleibenden Spuren geborenen Elementare noch immer durch die Lande.</i>

items.Ingredient_Void_Essence.name = Essenz der Leere
items.Ingredient_Void_Essence.description = <i>Es ist unklar, ob Kreaturen der Leere diese Essenz hervorbringen oder ob ihre Anwesenheit nötig ist, um ihre Existenz zu erhalten. Sicher ist nur, dass beides untrennbar miteinander verbunden ist.</i>

items.Ingredient_Water_Essence.name = Essenz des Wassers
items.Ingredient_Water_Essence.description = <i>Sogar Fische haben eine natürliche Affinität zu Magie. Während Wasser durch ihre Kiemen strömt, steigt die Konzentration. Vielleicht liegt darin das Geheimnis der abyssalen Kreaturen, die in Orbis’ dunkelsten Tiefen lauern.</i>

