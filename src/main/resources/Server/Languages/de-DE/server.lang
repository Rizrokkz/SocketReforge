items.PortalKey.description = Im <item is="Portal_Device"/> platzieren, um dieses Fragment zu besuchen.\nIn Arbeit
items.PortalKey_Windsurf_Valley.name = Fragment: Orbis – Windreiter-Tal
items.PortalKey_Windsurf_Valley.description = <msg key="server.items.PortalKey.description"/>\n\n<i>Für einen Feran ist Freiheit das höchste Gut – und nirgends zeigt sie sich so sehr wie in den Winden des Windreiter-Tals.</i>
items.PortalKey_Jungles.name = Fragment: Orbis – Tal'Kesi-Zuflucht
items.PortalKey_Jungles.description = <msg key="server.items.PortalKey.description"/>\n\n<i>Tief unter den öden Ödlanden einer uralten Zivilisation gedeiht ein urzeitlicher Zufluchtsort.</i>
items.PortalKey_Taiga.name = Fragment: Orbis – Drachenzinnenwald
items.PortalKey_Taiga.description = <msg key="server.items.PortalKey.description"/>\n\n<i>Es gibt gefrorene Wälder, in die sich nicht einmal ein Outlander wagt – egal wie sehr die Flüstern locken.</i>
items.PortalKey_Hederas_Lair.name = Fragment: Orbis – Der Schreckensmorast
items.PortalKey_Hederas_Lair.description = <msg key="server.items.PortalKey.description"/>\n\n<i>Nur wenige haben die Schrecken erlebt, die in Orbis’ trüberen Tiefen lauern.</i>
items.PortalKey_Henges.name = Fragment: Orbis – Stille Henge
items.PortalKey_Henges.description = <msg key="server.items.PortalKey.description"/>\n\n<i>Geheimnisvolle Henge ragen über ein gefrorenes Land.</i>

items.Portal_Device.name = Antikes Portal
items.Portal_Device.description = Platziere dies in deiner Basis, um die Barrieren zu zerreißen und zu anderen Fragmenten zu reisen!<i>\nIn Arbeit.\n\nAuch wenn der Fluch Gaias Orbis versiegelt, gibt es Wege, die Leere zu durchdringen, die es verhüllt.</i>

