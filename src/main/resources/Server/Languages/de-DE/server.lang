items.Ingredient_Bar_Adamantite.name = Adamantitbarren
items.Ingredient_Bar_Adamantite.description = <item is="Ore_Adamantite"/> erfordert eine hochwertige Spitzhacke, um abgebaut zu werden.\n\n<i>Dieses seltene Metall war einst entscheidend für die Fortschritte, die die Völker von Crucible erzielten. Auch wenn von der einstigen Pracht der Stadt kaum noch etwas übrig ist, lassen sich Spuren des widerstandsfähigen Erzes noch in den Tiefen unter diesen verbrannten Landen finden.</i>

items.Ingredient_Bar_Bronze.name = Bronzebarren

items.Ingredient_Bar_Cobalt.name = Kobaltbarren
items.Ingredient_Bar_Cobalt.description = <i>In der Mythologie der Outlander heißt es, dieses Metall sei selbst im geschmolzenen Zustand kalt. Das zu überprüfen wäre unklug – doch seine Herkunft in den eisigen Gipfeln und gefrorenen Höhlen ihres Gebiets verleiht der Geschichte eine gewisse Glaubwürdigkeit.</i>

items.Ingredient_Bar_Copper.name = Kupferbarren
items.Ingredient_Bar_Copper.description = Ein gewöhnliches Metall, das aus Erz geschmolzen wird und in allen Regionen von Orbis vorkommt.

items.Ingredient_Bar_Gold.name = Goldbarren

items.Ingredient_Bar_Iron.name = Eisenbarren
items.Ingredient_Bar_Iron.description = Seine natürliche Häufigkeit und zuverlässige Stärke machen es zum idealen Material für gängige Werkzeuge und Waffen.

items.Ingredient_Bar_Mithril.name = Mithrilbarren
items.Ingredient_Bar_Onyxium.name = Onyxiumbarren
items.Ingredient_Bar_Prisma.name = Prismabarren
items.Ingredient_Bar_Silver.name = Silberbarren

items.Ingredient_Bar_Thorium.name = Thoriumbarren
items.Ingredient_Bar_Thorium.description = <i>Auch wenn die Feran dieses Metall selbst nicht verwenden, wachen sie aufmerksam über seine Vorkommen in den sonnenverbrannten Wüsten und trockenen Ödlanden. Sollten ihre uralten Feinde jemals zurückkehren, wären diese Reserven die ersten, die sie zu ernten versuchten.</i>

items.Ingredient_Bolt_Cindercloth.name = Ballen Cindercloth
items.Ingredient_Bolt_Cotton.name = Ballen Baumwolle
items.Ingredient_Bolt_Linen.name = Ballen Leinen
items.Ingredient_Bolt_Prismaloom.name = Ballen Prismaloom
items.Ingredient_Bolt_Shadoweave.name = Ballen Shadoweave
items.Ingredient_Bolt_Silk.name = Ballen Seide
items.Ingredient_Bolt_Stormsilk.name = Ballen Stormsilk
items.Ingredient_Bolt_Wool.name = Ballen Wolle

items.Ingredient_Bone_Fragment.name = Knochenfragmente
items.Ingredient_Bone_Fragment.description = <i>Orbis’ fortschrittlichste Zivilisationen hatten eine Gemeinsamkeit: den Hochmut, der letztlich zu ihrem Untergang führte. Diese Knochenfragmente – und das verfluchte Wesen, aus dem sie geborgen wurden – sollten daran erinnern, dass manche Wege besser unbeschritten bleiben.</i>

items.Ingredient_Charcoal.name = Holzkohle

items.Ingredient_Crystal_Blue.name = Blaue Kristallsplitter
items.Ingredient_Crystal_Cyan.name = Cyanfarbene Kristallsplitter
items.Ingredient_Crystal_Green.name = Grüne Kristallsplitter
items.Ingredient_Crystal_Purple.name = Violette Kristallsplitter
items.Ingredient_Crystal_Red.name = Rote Kristallsplitter
items.Ingredient_Crystal_White.name = Weiße Kristallsplitter
items.Ingredient_Crystal_Yellow.name = Gelbe Kristallsplitter

items.Ingredient_Fabric_Scrap_Cindercloth.name = Cindercloth-Fetzen
items.Ingredient_Fabric_Scrap_Cindercloth.description = <i>Als die verfluchte Flamme Crucible verwüstete, blieb nichts unverändert. Selbst diese Stofffetzen – geborgen aus den verkohlten Knochen eines ehemaligen Bewohners – geben weiterhin eine unheimliche Hitze ab.</i>

items.Ingredient_Fabric_Scrap_Cotton.name = Baumwollfetzen

items.Ingredient_Fabric_Scrap_Linen.name = Leinenfetzen
items.Ingredient_Fabric_Scrap_Linen.description = Fetzen eines gewöhnlichen Stoffes, den viele Spezies von Orbis zur Herstellung ihrer Kleidung verwenden.

items.Ingredient_Fabric_Scrap_Prismaloom.name = Prismaloom-Fetzen

items.Ingredient_Fabric_Scrap_Shadoweave.name = Shadoweave-Fetzen
items.Ingredient_Fabric_Scrap_Shadoweave.description = <i>Dieser schwere Stoff, erfüllt von einer stillen, grüblerischen Dunkelheit, wurde von den Outlandern vor ihrer ersten Zwiesprache mit dem Void entwickelt. Obwohl er noch immer ein Kernbestandteil ihrer Gewandung ist, ist das Geheimnis seiner Herstellung längst verloren gegangen.</i>

items.Ingredient_Fabric_Scrap_Silk.name = Seidenfetzen
items.Ingredient_Fabric_Scrap_Stormsilk.name = Stormsilk-Fetzen
items.Ingredient_Fabric_Scrap_Wool.name = Wollfetzen

