// Weapon Stats HUD UI - Minimal Version
$Common = "Common.ui";
@MyTex = PatchStyle(TexturePath: "socket_panel_bg.png");

Group {
  LayoutMode: Center;
  Group #WeaponStatsBase {
    LayoutMode: Top;
    Visible: false;
    Background: @MyTex;
    Anchor: (Width: 300, Height: 400);
    Label #WeaponName {
      Anchor: (Top: 20);
      Text: "Weapon Name";
      Style: (HorizontalAlignment: Center, FontSize: 24, TextColor: #FFD700);
    }
    Label #WeaponLevel {
      Anchor: (Top: 60);
      Text: "Level: 1";
      Style: (HorizontalAlignment: Center, FontSize: 16, TextColor: #FFFFFF);
    }
    Label #WeaponDamage {
      Anchor: (Top: 90);
      Text: "Damage: 100";
      Style: (HorizontalAlignment: Center, FontSize: 16, TextColor: #55FF55);
    }
    Label #WeaponProgress {
      Anchor: (Top: 120);
      Text: "Progress: 0%";
      Style: (HorizontalAlignment: Center, FontSize: 14, TextColor: #55FFFF);
    }
  }
  Group #WeaponStatsNext {
    LayoutMode: Top;
    Visible: false;
    Background: @MyTex;
    Anchor: (Width: 300, Height: 200);
    Label #NextWeaponName {
      Anchor: (Top: 20);
      Text: "Next Level";
      Style: (HorizontalAlignment: Center, FontSize: 20, TextColor: #FFD700);
    }
    Label #NextWeaponLevel {
      Anchor: (Top: 50);
      Text: "Level: 2";
      Style: (HorizontalAlignment: Center, FontSize: 16, TextColor: #FFFFFF);
    }
    Label #NewWeaponDamage {
      Anchor: (Top: 80);
      Text: "Damage: 105";
      Style: (HorizontalAlignment: Center, FontSize: 16, TextColor: #55FF55);
    }
  }
  Group #WeaponStatsMax {
    LayoutMode: Top;
    Visible: false;
    Background: @MyTex;
    Anchor: (Width: 300, Height: 150);
    Label #WeaponNameMax {
      Anchor: (Top: 20);
      Text: "MAX LEVEL";
      Style: (HorizontalAlignment: Center, FontSize: 20, TextColor: #FFD700);
    }
    Label #WeaponLevelMax {
      Anchor: (Top: 50);
      Text: "Level: MAX";
      Style: (HorizontalAlignment: Center, FontSize: 16, TextColor: #FFFFFF);
    }
    Label #WeaponDamageMax {
      Anchor: (Top: 80);
      Text: "Damage: 1000";
      Style: (HorizontalAlignment: Center, FontSize: 16, TextColor: #55FF55);
    }
  }
}
