# Sistema de Refinamento de Itens
items.Ingredient_Refinement_Glob.name = Glob de Refinamento
items.Ingredient_Refinement_Glob.description = Feito a partir de minério de ferro sucateado. Usado para refinar equipamentos.
items.Bench_Refinement_Anvil.name = Bigorna de Refinamento
items.Bench_Refinement_Anvil.description = Uma bancada de trabalho para refinar equipamentos usando Globs de Refinamento
items.Tool_Hammer_Thorium.name = Martelo de Thorium do Construtor
items.Tool_Hammer_Thorium.description = Usado para alterar a aparência de blocos de construção estruturais.\n\nUma versão aprimorada do martelo bruto com maior durabilidade.\n\nDiminui ainda mais as chances de quebrar ao refinar equipamentos.
items.Resonant_Recipe.name = Receita de Ressonância
items.Resonant_Recipe.description = Uma página rasgada que sugere uma ressonância oculta.
items.Resonant_Compendium.name = Compendium Ressonante
items.Resonant_Compendium.description = Armazena e mescla fragmentos de receitas ressonantes.\n\nUse para absorver fragmentos de receitas do seu inventário.\nClique secundário para abrir o compêndio e extrair receitas completas.
# Sistema de Soquetes
items.Bench_Socket_Punch.name = Bancada de Punção de Soquete
items.Bench_Socket_Punch.description = Uma bancada de trabalho para punir soquetes em equipamentos
items.Socket_Puncher.name = Punidor de Soquete
items.Socket_Puncher.description = Uma ferramenta usada para punir soquetes em equipamentos
items.Socket_Stabilizer.name = Estabilizador de Soquete
items.Socket_Stabilizer.description = Aumenta a chance de sucesso na punção de soquete e reduz a chance de quebra
items.Socket_Reinforcer.name = Reforçador de Soquete
items.Socket_Reinforcer.description = Aumenta muito a chance de sucesso na punção de soquete
items.Socket_Guarantor.name = Garantidor de Soquete
items.Socket_Guarantor.description = Garante o sucesso na punção de soquete, mas não protege contra quebra
items.Socket_Expander.name = Expansor de Soquete
items.Socket_Expander.description = Chance de adicionar um soquete extra em caso de sucesso

