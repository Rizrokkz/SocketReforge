# Procs de ressonância
resonance.proc.burn_on_crit = Ao atingir: 22% de chance (0,7s de recarga) de causar +8% de dano bônus (mín. +1).
resonance.proc.chain_slow = Ao atingir: 25% de chance (2,0s de recarga) de congelar o alvo por 1,5s.
resonance.proc.execute = Ao atingir: causa +20% de dano em alvos com 25% de HP ou menos.
resonance.proc.armor_shred = Ao atingir: 30% de chance (0,9s de recarga) de causar +10% de dano.
resonance.proc.thunder_strike = Ao atingir: 20% de chance (1,2s de recarga) de causar +10% de dano bônus (mín. +1).
resonance.proc.multishot_barrage = Ao acertar projétil: 20% de chance (1,6s de recarga) de disparar 2 flechas extras causando 35% de dano cada.
resonance.proc.crossbow_auto_reload = Ao acertar projétil: 35% de chance de reembolsar 1 flecha/projétil ao inventário.
resonance.proc.plundering_blade = Ao atingir: 15% de chance (2,5s de recarga) de roubar um item da tabela de drop do NPC.
resonance.proc.frost_nova_on_hit = Ao sofrer golpe: 25% de chance (4,0s de recarga) de congelar o atacante por 1,5s.
resonance.proc.thorns_shock = Ao sofrer golpe: reflete 6% do dano recebido como Choque (mín. 1).
resonance.proc.cheat_death = Prevenção de morte: uma vez a cada 60s, sobreviva com 1 HP.
resonance.proc.heal_surge.weapon = Ao atingir: cura 10% do dano causado (mín. 1) a cada 1,8s.
resonance.proc.heal_surge.armor = Ao sofrer golpe: cura 5% do dano recebido (mín. 1) a cada 5,0s.
resonance.proc.shock_dodge = Ao esquivar: 20% de chance (3,5s de recarga) de retaliar com 4% do dano recebido (mín. 1).
resonance.proc.aura_burn = Ao sofrer golpe: 20% de chance (0,9s de recarga) de queimar o atacante por 5% do dano recebido (mín. 1).

